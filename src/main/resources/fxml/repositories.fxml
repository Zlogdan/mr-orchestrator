<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mrOrchestrator.ui.RepositoriesController">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label text="Репозитории" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <TableView fx:id="repositoriesTable" editable="true" prefWidth="720" prefHeight="320" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="enabledColumn" text="Включен" prefWidth="90"/>
            <TableColumn fx:id="urlColumn" text="URL репозитория" prefWidth="600"/>
        </columns>
        <placeholder>
            <Label text="Нет репозиториев. Добавьте URL репозитория."/>
        </placeholder>
    </TableView>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Добавить" onAction="#onAdd"/>
        <Button text="Удалить" onAction="#onRemove"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Сохранить" onAction="#onSave" style="-fx-font-weight: bold;" defaultButton="true"/>
        <Button text="Отмена" onAction="#onCancel" cancelButton="true"/>
    </HBox>
</VBox>
